# Unganisha AI - Environment Configuration

# Database: Leave blank or set to postgresql://username:password@localhost:5432/database_name
# If blank or connection fails, the app will automatically fall back to sqlite:///./unganisha.db
DATABASE_URL=

# JWT Authentication secret key (for token encoding/decoding)
JWT_SECRET_KEY=unganisha-ai-super-secret-development-key-12345

# OpenAI API Key (for profile parsing and warm introduction emails)
# If blank, the app will fall back to local rule-based and template engines
OPENAI_API_KEY=
